Thumbs.db
desktop.ini

# --- LFS-tracked assets ---
# These are source assets you *do* want in Git, but through LFS:
# (Run: git lfs track "*.psd" "*.png" "*.fbx" "*.wav" "*.mp4" etc.)
*.psd
*.png
*.jpg
*.jpeg
*.tga
*.tif
*.tiff
*.fbx
*.obj
*.wav
*.mp3
*.mp4
*.prefab
*.unity
*.anim

Library/
Temp/
Obj/
Logs/
MemoryCaptures/
Build/
Builds/
CodeCoverage/

!DotNetBuild/*.csproj
CodeCoverageResults/
**/TestResults_*.xml
Packages/TestResults_*.xml
Backups/
_audit/
_diag*/
_backup_*/

# ---- AQ contract prefabs (tests rely on these) ----
!/Assets/Resources/App/UI/Prefabs/
!/Assets/Resources/App/UI/Prefabs/*.prefab
!/Assets/Resources/App/UI/Prefabs/*.meta


