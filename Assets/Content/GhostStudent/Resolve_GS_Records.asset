  m_Script: {fileID: 11500000, guid: 7e8140d05737a11468020c371c32ff33, type: 3}
  m_Name: Resolve_GS_Records
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: GS_REC_R1
  nodes:
  - id: GS_REC_R1
    speaker: Ally Quinn
    line: "I called in a favour from IT services. Maya's enrollment profile shows fourteen
      remote login attempts in the two weeks before she disappeared. None of them
      originated from her student device."
    portrait: {fileID: 21300000, guid: e02460f0c092dde4891723eecbbdc368, type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_REC_R2
    choices: []
  - id: GS_REC_R2
    speaker: Ally Quinn
    line: "Her attendance record is perfect. Three years — every lecture, every
      lab submission, every library swipe. Not one gap. Either Maya Chen had the discipline
      of a machine, or someone was running her academic profile from the outside."
    portrait: {fileID: 21300000, guid: ae0c3985c1991244d8ee72fa0756eb08, type: 3}
    emotion: 6
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_REC_R3
    choices: []
  - id: GS_REC_R3
    speaker: Ally Quinn
    line: "I filtered for the same pattern. Six students. Six sets of perfect records,
      six ghost identities running in parallel. Maya wasn't the first. She was just
      the first one who found out what she was."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag: aq.lead.gs_records.seen
    nextId:
    choices: []
