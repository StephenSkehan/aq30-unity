  m_Name: Resolve_GS_Money
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: GS_MON_R1
  nodes:
  - id: GS_MON_R1
    speaker: Ally Quinn
    line: "Ghost students pay full tuition. Someone pays for them. I traced the payment
      routing on six ghost accounts — all of them settled through a single intermediary.
      Northgate Education Partners, registered in the Cayman Islands."
    portrait: {fileID: 21300000, guid: e02460f0c092dde4891723eecbbdc368, type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_MON_R2
    choices: []
  - id: GS_MON_R2
    speaker: Ally Quinn
    line: "Northgate dissolved in 2012 and re-registered as Voss Bio Holdings. Voss
      Bio appears in Havenbay city development filings going back to 2008. Someone
      is using Havenbay University as infrastructure. This is not a university scheme."
    portrait: {fileID: 21300000, guid: ae0c3985c1991244d8ee72fa0756eb08, type: 3}
    emotion: 4
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_MON_R3
    choices: []
  - id: GS_MON_R3
    speaker: Ally Quinn
    line: "The principal behind Voss Bio is behind enough shell layers that I can't
      reach them from here. I need someone who knows how these networks are built.
      I need Gerald."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
