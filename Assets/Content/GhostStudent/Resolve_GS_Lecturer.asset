  m_Script: {fileID: 11500000, guid: 7e8140d05737a11468020c371c32ff33, type: 3}
  m_Name: Resolve_GS_Lecturer
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: GS_LEC_R1
  nodes:
  - id: GS_LEC_R1
    speaker: Ally Quinn
    line: "He asked me twice if I was recording before he'd say a word.
      Professor Drake — fifteen years at Havenbay, never once put a foot wrong.
      Now he's terrified of his own office."
    portrait: {fileID: 3757819190876562394, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_LEC_R2
    choices: []
  - id: GS_LEC_R2
    speaker: Ally Quinn
    line: "Three days before Maya vanished, she came to his office. She said
      someone in the faculty had sold student biometric data to a private
      research firm. She had a name. He told her to go to administration.
      He didn't know that was the worst advice he could give her."
    portrait: {fileID: 3757819190876562394, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 6
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_LEC_R3
    choices: []
  - id: GS_LEC_R3
    speaker: Ally Quinn
    line: "He wouldn't say the name out loud. But when he walked me to the door
      he left a notepad face-down on the desk. I need to know whose name
      was on it."
    portrait: {fileID: 3757819190876562394, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag: aq.lead.gs_lecturer.seen
    nextId:
    choices: []
