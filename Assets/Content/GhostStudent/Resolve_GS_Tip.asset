  m_Script: {fileID: 11500000, guid: 7e8140d05737a11468020c371c32ff33, type: 3}
  m_Name: Resolve_GS_Tip
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: GS_TIP_R1
  nodes:
  - id: GS_TIP_R1
    speaker: Ally Quinn
    line: "It took half the night to crack the cipher. Maya used a military-grade
      symmetric key — the kind you don't find in a standard toolkit. She was
      scared enough to learn it."
    portrait: {fileID: -5112325403583219243, guid: e02460f0c092dde4891723eecbbdc368,
      type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_TIP_R2
    choices: []
  - id: GS_TIP_R2
    speaker: Ally Quinn
    line: "Three words in the decrypted file: 'They're selling us.' Sent to an
      encrypted relay two days before she vanished. No recipient on record.
      No follow-up message. Just those three words and then silence."
    portrait: {fileID: -5758400864172228007, guid: 7e03a4f198056f44ba2209764d9e8219,
      type: 3}
    emotion: 4
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_TIP_R3
    choices: []
  - id: GS_TIP_R3
    speaker: Ally Quinn
    line: "Students. Data. Something with a price tag attached. Someone at
      Havenbay University knew she'd found it — and made sure she couldn't
      talk. I need to find who she trusted before the end."
    portrait: {fileID: 3757819190876562394, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag: aq.lead.gs_tip.seen
    nextId:
    choices: []
