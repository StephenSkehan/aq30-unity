  startId: BETH_R1
  nodes:
  - id: BETH_R1
    speaker: Ally Quinn
    line: "Beth's a talker once she warms up. Let her vent about the rent,
      then I asked about the student. She went quiet for just a second."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
