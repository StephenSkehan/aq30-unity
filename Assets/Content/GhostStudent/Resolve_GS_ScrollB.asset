  m_Script: {fileID: 11500000, guid: 7e8140d05737a11468020c371c32ff33, type: 3}
  m_Name: Resolve_GS_ScrollB
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: GS_DEPT_R1
  nodes:
  - id: GS_DEPT_R1
    speaker: Ally Quinn
    line: "Department Head Dr. Elaine Voss. She signed Maya's enrolment forms,
      her scholarship renewal, her lab access. Every piece of paper that put
      Maya inside that building had Voss's signature on it."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 6
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_DEPT_R2
    choices: []
  - id: GS_DEPT_R2
    speaker: Ally Quinn
    line: "I've called six times. Her assistant keeps telling me she's in meetings.
      This morning I waited outside the faculty building for two hours. She
      walked straight past me to her car. She knew exactly who I was."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 3
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag:
    nextId: GS_DEPT_R3
    choices: []
  - id: GS_DEPT_R3
    speaker: Ally Quinn
    line: "People who are innocent ignore journalists. People who are guilty
      ignore them harder. Dr. Voss isn't returning calls because she can't
      afford to. That tells me she knows exactly where this trail leads."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad,
      type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag:
    skipIfFlagMissing: 1
    setsFlag: aq.lead.gs_scroll_b.seen
    nextId:
    choices: []
