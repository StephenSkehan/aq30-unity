  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e8140d05737a11468020c371c32ff33, type: 3}
  m_Name: Resolve_E1_Close
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: E1_L12_N1
  stageBackground: {fileID: 21300000, guid: b61e15d0a1b2c3d4e5f6a7b8c9d0e103, type: 3}
  nodes:
  - id: E1_L12_N1
    speaker: "Ally Quinn"
    line: "This is Echoes of Havenbay. Dot Ellis is safe. She was found through the life she left in plain sight — a school, a parish, a bus route, and three years of messages nobody had thought to treat as evidence. She declined an interview. Her words: \"I'm not content, love. I'm a person.\""
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N2A
    choices: []
  - id: E1_L12_N2A
    speaker: "Ally Quinn"
    line: "On the record: the van traces to Harbourline Security — dissolved in 2011, still driving. You heard the full track when we did, and it worked, and it cost: two hundred ghosts in the queue, and the van gone before police reached it. Loud truth. I'd choose it again. I think."
    portrait: {fileID: 21300000, guid: e02460f0c092dde4891723eecbbdc368, type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: aq.e1.truth_public
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N2B
    choices: []
  - id: E1_L12_N2B
    speaker: "Ally Quinn"
    line: "On the record: the van traces to a dissolved port-security company. Del has asked me to keep its name off this feed — and this time, I'm listening. Quiet truth cost an afternoon of silence I don't want to spend again. I'd choose it again. I think."
    portrait: {fileID: 21300000, guid: e02460f0c092dde4891723eecbbdc368, type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: aq.e1.truth_protected
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N3
    choices: []
  - id: E1_L12_N3
    speaker: "Ally Quinn"
    line: "And one thing changes at this show, starting tonight: a voice can tell us where to look without me telling everyone else where it lives. That's the new rule. Dot wrote it; I'm just reading it out."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N4
    choices: []
  - id: E1_L12_N4
    speaker: "Ally Quinn"
    line: "And now — not as a reporter, but to the man with the careful walk: this show is built on listening. This case taught me who else does. She's safe. The evidence is safe. You're the only one still hiding."
    portrait: {fileID: 21300000, guid: e02460f0c092dde4891723eecbbdc368, type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N5
    choices: []
  - id: E1_L12_N5
    speaker: "Dot Ellis (voicemail)"
    line: "It's Dot. Not from Rivermouth tonight — imagine that. Vera says hello, which for Vera is a parade. You found an old woman who didn't want a fuss and you made one anyway. Good girl. Say goodnight to the harbour for me, Ally."
    portrait: {fileID: 21300000, guid: d07a4b5c6d7e8f90a1b2c3d4e5f6a702, type: 3}
    emotion: 1
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N6
    choices: []
  - id: E1_L12_N6
    speaker: "Ally Quinn"
    line: "Goodnight, Dot. Goodnight, harbour. — The tip line stays open."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L12_N7
    choices: []
  - id: E1_L12_N7
    speaker: "—"
    line: "[Somewhere: this episode, playing. A click. Silence. A diesel engine starts.]"
    portrait: {fileID: 0}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: aq.lead.e1_close.seen
    nextId: 
    choices: []
