  m_Name: Resolve_E1_Archive
  m_EditorClassIdentifier: AQ.App::AQ.App.CaseGraph
  startId: E1_L3_N1
  stageBackground: {fileID: 21300000, guid: b61e15d0a1b2c3d4e5f6a7b8c9d0e101, type: 3}
  nodes:
  - id: E1_L3_N1
    speaker: "Ally Quinn"
    line: "Three years of messages, most under a minute. I used to pick one to close the show — Dot knew, and loved it. \"Play the one about the gulls,\" she told me once. \"I was very good in that one.\""
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L3_N2
    choices: []
  - id: E1_L3_N2
    speaker: "Ally Quinn"
    line: "Tonight they're not a closing segment. They're a map. A school bell in the daytime messages — half past eight, then noon, term time only. And under the late calls, a low mechanical note every twenty-odd seconds."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L3_N3
    choices: []
  - id: E1_L3_N3
    speaker: "Ally Quinn"
    line: "And the boats. Years of them, mentioned like weather. Then three weeks ago the message changed: \"the pretty one came close tonight — two-note horn, no lights, and a funny mark on the funnel, like a fish-hook.\" I played that one on the show."
    portrait: {fileID: 21300000, guid: e02460f0c092dde4891723eecbbdc368, type: 3}
    emotion: 5
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: 
    nextId: E1_L3_N4
    choices: []
  - id: E1_L3_N4
    speaker: "Ally Quinn"
    line: "A school that rings at eight-thirty and noon. A machine that breathes every twenty seconds. Gerald has heard every machine this city ever built. Time to buy my grandfather a drink."
    portrait: {fileID: 21300000, guid: 792b5f88f6dd2724d84b6954cc0b5fad, type: 3}
    emotion: 0
    voiceClip: {fileID: 0}
    waitForAudio: 0
    requiresFlag: 
    skipIfFlagMissing: 1
    setsFlag: aq.lead.e1_archive.seen
    nextId: 
    choices: []
