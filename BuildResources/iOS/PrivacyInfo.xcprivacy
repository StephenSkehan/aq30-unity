<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App-level privacy manifest. The Firebase and Google Mobile Ads SDKs ship
	     their OWN .xcprivacy manifests inside their frameworks; Apple aggregates
	     all of them. This file declares (a) the required-reason APIs the app's
	     own / Unity-engine code uses — the item whose absence blocks the upload —
	     and (b) the app's first-party data collection. See BuildResources/iOS/README.md. -->

	<!-- (a) Required-reason APIs. Unity's published baseline for iOS apps. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults: Unity PlayerPrefs. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array><string>CA92.1</string></array>
		</dict>
		<dict>
			<!-- File timestamps: the save system (BoardSaveSystem) reads/writes its
			     own container files. If a reviewer queries this, 3B52.1 (app-container
			     access) is the alternative reason — see README. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array><string>C617.1</string></array>
		</dict>
		<dict>
			<!-- System boot time: elapsed-time measurement (Unity/analytics timing). -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array><string>35F9.1</string></array>
		</dict>
		<dict>
			<!-- Disk space: checked before writes (saves, caches). -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array><string>E174.1</string></array>
		</dict>
	</array>

	<!-- (b) Tracking. The app serves personalized ads via AdMob behind the ATT
	     prompt, so app-wide tracking is true. The AdMob SDK's own bundled manifest
	     declares its tracking domains; the app's first-party code contacts none,
	     so this list is intentionally empty. Add a domain here only if first-party
	     app code ever connects directly to a tracking domain. -->
	<key>NSPrivacyTracking</key>
	<true/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- (c) First-party collected data (Firebase Analytics + Crashlytics). AdMob's
	     own collection (Device ID / Advertising Data / Coarse Location) is declared
	     by AdMob's bundled manifest and is NOT duplicated here. None of the below is
	     linked to the user's identity or used for tracking. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array><string>NSPrivacyCollectedDataTypePurposeAnalytics</string></array>
		</dict>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeCrashData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePerformanceData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
	</array>
</dict>
</plist>
